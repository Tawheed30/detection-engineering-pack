SELECT
  sourceip AS src_ip,
  UNIQUECOUNT(username) AS distinct_users,
  COUNT(*) AS fail_count,
  MIN(starttime) AS first_seen,
  MAX(starttime) AS last_seen
FROM events
WHERE
  QIDNAME(qid) ILIKE '%4625%' OR (eventid = 4625)
  AND starttime > (CURRENT_TIMESTAMP - 10 MINUTES)
  AND sourceip IS NOT NULL
  AND username IS NOT NULL
GROUP BY src_ip
HAVING distinct_users >= 6
ORDER BY distinct_users DESC
